<Window x:Class="BASpark.ControlPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BASpark - 控制面板" Height="650" Width="680"
        WindowStartupLocation="CenterScreen" Background="#F5F7FA" Icon="app.ico">
    
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Name="b" CornerRadius="5" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#45AFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E0F2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator x:Name="RootBullet" Background="Transparent" Cursor="Hand">
                            <BulletDecorator.Bullet>
                                <Grid Width="40" Height="20">
                                    <Border x:Name="Background" Background="#DDD" CornerRadius="10" />
                                    <Border x:Name="Dot" Width="14" Height="14" Background="White" CornerRadius="7" HorizontalAlignment="Left" Margin="3,0">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="Trans" X="0"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="#45AFFF"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Trans" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Trans" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Background" Property="Background" Value="#E0E0E0"/>
                                <Setter TargetName="Dot" Property="Background" Value="#F5F5F5"/>
                                <Setter TargetName="RootBullet" Property="Cursor" Value="No"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,30,0,0">
                <TextBlock Text="✨ BASpark" FontSize="20" FontWeight="Bold" Foreground="#45AFFF" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                <RadioButton Name="TabWelcome" Content="首页" Style="{StaticResource NavBtn}" IsChecked="True" Click="Tab_Click"/>
                <RadioButton Name="TabSettings" Content="设置" Style="{StaticResource NavBtn}" Click="Tab_Click"/>
                <RadioButton Name="TabAbout" Content="关于" Style="{StaticResource NavBtn}" Click="Tab_Click"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="30">
                
                <StackPanel Name="PageWelcome">
                    <Border x:Name="NoticeBar" Visibility="Collapsed" Background="#E3F2FD" CornerRadius="10" Padding="15" Margin="0,0,0,20" BorderBrush="#90CAF9" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📢" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="NoticeTitle" Text="加载中..." FontWeight="Bold" Foreground="#1976D2" FontSize="14"/>
                                <TextBlock x:Name="NoticeContent" Text="..." Margin="0,5,0,0" TextWrapping="Wrap" Foreground="#424242" FontSize="13" LineHeight="18"/>
                            </StackPanel>
                            <TextBlock x:Name="NoticeDate" Grid.Column="2" Text="" Foreground="#90CAF9" FontSize="10" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="欢迎回来，老师！" FontSize="28" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBlock Text="Sensei, welcome back!" FontSize="12" Foreground="#999" Margin="0,0,0,25"/>

                    <Border Background="#EBF5FF" CornerRadius="12" Padding="20" HorizontalAlignment="Left" MinWidth="300">
                        <StackPanel>
                            <TextBlock Text="实时统计" FontSize="14" FontWeight="Bold" Foreground="#45AFFF" Margin="0,0,0,15"/>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="当前状态:" Foreground="#666"/>
                                <TextBlock x:Name="StatusText" Text="工作中" HorizontalAlignment="Right" FontWeight="Bold" Foreground="Green"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="累计点击次数:" Foreground="#666"/>
                                <TextBlock x:Name="ClickCountText" Text="0 次" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="#333"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Name="PageSettings" Visibility="Collapsed">
                    <TextBlock Text="参数配置" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <CheckBox Name="CheckMasterSwitch" Content="启用鼠标点击特效" Style="{StaticResource ToggleSwitch}" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20"/>
                    <CheckBox Name="CheckAlwaysTrailEffectSwitch" Content="启用鼠标常驻拖尾" Style="{StaticResource ToggleSwitch}" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="特效主题颜色" Foreground="#666" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Name="ColorPreview" Width="35" Height="35" CornerRadius="4" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,10,0"/>
                        <Button Content="打开调色板..." Click="PickColor_Click" Width="100" Height="35" Background="White" BorderBrush="#CCC" Cursor="Hand"/>
                    </StackPanel>

                    <TextBlock Text="自定义大小" Foreground="#666" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/></Grid.ColumnDefinitions>
                        <Slider Name="SliderScale" Minimum="0.5" Maximum="3.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="EffectSlider_ValueChanged"/>
                        <TextBlock Name="TextScaleValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#333"/>
                    </Grid>

                    <TextBlock Text="透明度" Foreground="#666" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/></Grid.ColumnDefinitions>
                        <Slider Name="SliderOpacity" Minimum="0.1" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="EffectSlider_ValueChanged"/>
                        <TextBlock Name="TextOpacityValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#333"/>
                    </Grid>

                    <TextBlock Text="播放速度" Foreground="#666" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/></Grid.ColumnDefinitions>
                        <Slider Name="SliderSpeed" Minimum="0.2" Maximum="3.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="EffectSlider_ValueChanged"/>
                        <TextBlock Name="TextSpeedValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#333"/>
                    </Grid>

                    <TextBlock Text="拖尾刷新率（Hz）" Foreground="#666" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/></Grid.ColumnDefinitions>
                        <Slider Name="SliderTrailRefresh" Minimum="10" Maximum="240" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="EffectSlider_ValueChanged"/>
                        <TextBlock Name="TextTrailRefreshValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#333"/>
                    </Grid>

                    <CheckBox Name="CheckAutoStart" Content="开机自动启动" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,10" Checked="CheckAutoStart_Changed" Unchecked="CheckAutoStart_Changed"/>
                    <CheckBox Name="CheckStartSilent" Content="静默启动 (仅限开机自启)" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,10"/>
                    <CheckBox Name="CheckTelemetry" Content="允许发送匿名运行数据以改进软件" Style="{StaticResource ToggleSwitch}" Foreground="#666" Margin="0,0,0,30"/>
                    
                    <Button Content="保存并应用设置" Click="SaveSettings_Click" Width="150" Height="38" Background="#45AFFF" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                    </Button>
                </StackPanel>

                <StackPanel Name="PageAbout" Visibility="Collapsed">
                    <TextBlock Text="关于" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                            <Run Text="BASpark "/>
                            <Run x:Name="VersionText" Text="v1.1.0" Foreground="#45AFFF"/>
                        </TextBlock>
                        <Button Content="检查更新" Click="CheckUpdate_Click" Margin="15,0,0,0" Padding="10,2" Height="26" FontSize="12" Background="#E3F2FD" Foreground="#45AFFF" BorderBrush="#45AFFF" BorderThickness="1" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="深度复刻《蔚蓝档案》UI 风格动效的鼠标特效工具" Foreground="#666" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <Border Background="#FFF0F0" CornerRadius="6" Padding="12" Margin="0,0,0,20" BorderBrush="#FFCCCC" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" Margin="0,0,8,0" VerticalAlignment="Top"/>
                            <TextBlock Text="安全提示：请务必确保从 GitHub 官方仓库下载。第三方分发渠道的版本可能存在报毒风险或恶意篡改。" Foreground="#CC0000" FontSize="12" TextWrapping="Wrap" MaxWidth="380"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="如果你喜欢本应用，欢迎支持开发者持续维护 ☕" Foreground="#45AFFF" Margin="0,0,0,25"/>
                    
                    <Button Content="🌐 访问 GitHub 官方仓库" Tag="https://github.com/DoomVoss/BASpark" Click="OpenLink_Click" Width="220" Height="38" Background="#333" Foreground="White" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,10"/>
                    <Button Content="📺 关注 B 站官号" Tag="https://space.bilibili.com/3493116084488813" Click="OpenLink_Click" Width="220" Height="38" Background="#FB7299" Foreground="White" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,10"/>
                    <Button Content="💬 加入 QQ 交流群" Tag="https://qm.qq.com/q/lgvVto3yPm" Click="OpenLink_Click" Width="220" Height="38" Background="#12B7F5" Foreground="White" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,10"/>
                    <Button Content="☕ 赞助支持作者" Tag="https://qq.catbotstudio.top/jrys/spor.png" Click="OpenLink_Click" Width="220" Height="38" Background="#FF8140" Foreground="White" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,30"/>

                    <TextBlock Text="开发者选项" FontSize="14" FontWeight="Bold" Foreground="#999" Margin="0,15,0,10"/>
                    <Button Content="重置所有设置并退出" Click="ResetConfig_Click" Background="#FFE0E0" Foreground="#CC0000" BorderThickness="0" HorizontalAlignment="Left" Padding="15,8" Cursor="Hand"/>
                </StackPanel>
                
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>